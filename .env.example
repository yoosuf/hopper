# Environment Configuration
ENVIRONMENT=development

# Server Configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=hopper
DB_PASSWORD=hopper_password
DB_NAME=hopper_db
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# JWT Configuration
JWT_SECRET=your-secret-key-min-32-characters-long
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,Idempotency-Key
CORS_MAX_AGE=3600

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10
RATE_LIMIT_BY_IP=true
RATE_LIMIT_BY_USER=true

# Worker Configuration
WORKER_ENABLED=true
WORKER_POLL_INTERVAL=5s
WORKER_BATCH_SIZE=100
WORKER_MAX_RETRIES=5
WORKER_RETRY_BASE_DELAY=1s
WORKER_CONCURRENCY=10
WORKER_JOB_TIMEOUT=30s

# Worker Types
OUTBOX_WORKER_ENABLED=true
SCHEDULED_ACTIVATOR_WORKER_ENABLED=true
NOTIFICATION_WORKER_ENABLED=true
PAYMENT_RECONCILER_WORKER_ENABLED=true
MAINTENANCE_WORKER_ENABLED=true

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090

# SMTP Configuration (for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASSWORD=smtp-password
SMTP_FROM=noreply@hopper.example.com
SMTP_SKIP_TLS_VERIFY=false

# Payment Provider Configuration
PAYMENT_PROVIDER=mock
PAYMENT_PROVIDER_SECRET=provider-secret-key
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Courier Automation Feature Flags
COURIER_AUTO_DISPATCH_ENABLED=false
COURIER_ROUTE_OPTIMIZATION_ENABLED=false
COURIER_LIVE_TRACKING_ENABLED=false
COURIER_AUTO_REASSIGN_ENABLED=false
COURIER_SLA_MONITORING_ENABLED=false
COURIER_PROVIDER_INTEGRATIONS_ENABLED=false

# Courier Automation Tuning
COURIER_DISPATCH_RADIUS_KM=10
COURIER_REASSIGN_TIMEOUT=3m
COURIER_SLA_THRESHOLD=15m
COURIER_AVERAGE_SPEED_KPH=25

# Provider Selection
MAPS_PROVIDER=mock
SMS_PROVIDER=mock
PUSH_PROVIDER=mock

# External Provider Credentials
GOOGLE_MAPS_API_KEY=
MAPBOX_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
FIREBASE_SERVER_KEY=
FIREBASE_ENDPOINT=https://fcm.googleapis.com/fcm/send

# Idempotency
IDEMPOTENCY_ENABLED=true
IDEMPOTENCY_TTL=24h

# Redis Configuration (for distributed caching and rate limiting)
REDIS_ENABLED=false
REDIS_ADDRESS=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
